# 이 파일을 secrets.toml 로 복사한 뒤 값을 채우세요.
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# secrets.toml 은 .gitignore 에 잡혀 있어 커밋되지 않습니다.
#
# 현재 프로토타입은 샘플 데이터로 동작하므로 이 파일이 없어도 됩니다.
# 아래 값들은 실제 소스 연결 작업(lib/datasource/*.py 구현) 시점에 사용합니다.

[glue]
region = "ap-northeast-2"
# 자격증명은 가능한 한 AWS CLI 프로파일/환경변수(IAM Role)를 쓰세요.
# 부득이하게 직접 넣어야 한다면 읽기 전용 키만:
# aws_access_key_id = ""
# aws_secret_access_key = ""

[airflow]
# Airflow REST API (EKS 내부 엔드포인트 또는 포트포워딩 주소)
base_url = "https://airflow.example.internal"
username = ""
password = ""

[airbyte]
# Airbyte API
base_url = "https://airbyte.example.internal/api/v1"
username = ""
password = ""
