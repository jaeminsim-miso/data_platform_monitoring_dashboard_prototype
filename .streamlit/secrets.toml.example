# 이 파일을 secrets.toml 로 복사한 뒤 값을 채우세요.
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# secrets.toml 은 .gitignore 에 잡혀 있어 커밋되지 않습니다.
#
# 현재 프로토타입은 샘플 데이터로 동작하므로 이 파일이 없어도 됩니다.
# 아래 값들은 실제 소스 연결 작업(lib/datasource/*.py 구현) 시점에 사용합니다.

[glue]
# AWS SSO 프로파일로 인증 (로컬: aws sso login --profile miso 로 갱신)
profile = "miso"
# region = "ap-northeast-2"   # 미설정 시 프로파일 기본 리전 사용
# lookback_days = 7           # 조회 기간(일). 기본 7
# job_names = ["jobA", "jobB"]      # 지정 시 해당 잡만 조회 (초기 검증용). 미설정 시 태그 필터 적용
# DataLayer 태그로 표시 대상 잡을 제한 (기본 LINT/LEXT/STDZ). tag:GetResources 권한 필요.
# data_layers = ["LINT", "LEXT", "STDZ"]   # []  로 두면 필터 해제(전체 잡 조회)

[airflow]
# Airflow REST API (Stable /api/v1 + basic_auth)
# 로컬: kubectl -n airflow port-forward svc/airflow-webserver 8080:8080
base_url = "http://localhost:8080"
username = ""   # Viewer 롤 계정
password = ""
# 표시 대상 DAG 를 태그로 제한 (OR 매칭). 미설정 시 기본 layer:lint/lext/stdz + dbt.
# tags = ["layer:lint", "layer:lext", "layer:stdz", "dbt"]   # []  로 두면 필터 해제(전체 DAG)

[airbyte]
# Airbyte 메타DB(인클러스터 Postgres) 직접 조회.
# 로컬: kubectl -n airbyte port-forward svc/airbyte-db-svc 5432:5432
host = "localhost"
port = 5432
dbname = "db-airbyte"
user = "airbyte"
password = ""   # airbyte-db-0 의 POSTGRES_PASSWORD
# lookback_days = 7
